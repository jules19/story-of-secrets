{
  "name": "the-history-of-secrets",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "An interactive history of cryptography — the contest between making and breaking secrets.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/prerender.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run test && npm run build",
    "screenshots": "node scripts/screenshots.mjs"
  },
  "devDependencies": {
    "playwright": "^1.49.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
